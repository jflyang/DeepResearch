# === App ===
APP_ENV=development
LOG_LEVEL=INFO

# === Database ===
DATABASE_URL=sqlite:///./data/research.db

# === Obsidian ===
# 留空则可运行，但导出时会报错
OBSIDIAN_VAULT_PATH=

# === Search Provider API Keys ===
# 缺少 key 时对应 provider 自动禁用，不会报错
TAVILY_API_KEY=
BRAVE_API_KEY=
GOOGLE_BOOKS_API_KEY=

# === LLM (Ollama) ===
ENABLE_LLM=true
OLLAMA_BASE_URL=http://192.168.1.50:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=120

# === Cloud LLM ===
# 统一云端 LLM 开关与 Provider 选择
ENABLE_CLOUD_LLM=false
CLOUD_LLM_PROVIDER=deepseek
CLOUD_LLM_TIMEOUT_SECONDS=120

# === Cloud LLM: DeepSeek ===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash

# === Cloud LLM: OpenAI ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4.1-mini

# === Cloud LLM: Generic OpenAI-compatible ===
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_DEFAULT_MODEL=

# === Search Defaults ===
DEFAULT_SEARCH_DEPTH=3
DEFAULT_RESULT_LIMIT=10

# === Provider Toggles ===
ENABLE_TAVILY=false
ENABLE_BRAVE=false
ENABLE_GOOGLE_BOOKS=true

# === Free Search Providers (MVP) ===
SEARCH_MODE=free_first

# SearXNG - 通用网页搜索（需自托管实例）
ENABLE_SEARXNG=true
SEARXNG_BASE_URL=http://localhost:8080
SEARXNG_TIMEOUT_SECONDS=20

# Open Library - 图书资料搜索（免费，无需 key）
ENABLE_OPEN_LIBRARY=true

# Crossref - 论文/学术元数据搜索（免费，无需 key）
ENABLE_CROSSREF=true
CROSSREF_MAILTO=
CROSSREF_TIMEOUT_SECONDS=20

# arXiv - 论文搜索（免费，无需 key）
ENABLE_ARXIV=true
ARXIV_TIMEOUT_SECONDS=20

# Wikipedia - 实体消歧与背景参考（免费，无需 key）
ENABLE_WIKIPEDIA=true
WIKIPEDIA_LANGUAGE=en
WIKIPEDIA_TIMEOUT_SECONDS=20

# === Scoring Weights (0.0 - 1.0) ===
SCORING_AUTHORITY_WEIGHT=0.3
SCORING_RELEVANCE_WEIGHT=0.4
SCORING_ORIGINALITY_WEIGHT=0.2
SCORING_GOSSIP_PENALTY=0.1

# === Crawlee 网页抓取 ===
ENABLE_CRAWLEE=true
CRAWLEE_DEFAULT_MODE=adaptive
CRAWLEE_MAX_CONCURRENCY=3
CRAWLEE_TIMEOUT_SECONDS=30
CRAWLEE_RESPECT_ROBOTS_TXT=true

# === Optional: Google Custom Search API ===
# 用于获取 Google 搜索结果 URL 候选（合规方式）
ENABLE_GOOGLE_CUSTOM_SEARCH=false
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# === Optional: SerpAPI ===
ENABLE_SERPAPI=false
SERPAPI_API_KEY=

# === Optional: Serper.dev ===
ENABLE_SERPER=false
SERPER_API_KEY=
