# === App ===
APP_ENV=development
LOG_LEVEL=INFO

# === Database ===
DATABASE_URL=sqlite:///./data/research.db

# === Obsidian ===
# 留空则可运行，但导出时会报错
OBSIDIAN_VAULT_PATH=

# === Search Provider API Keys ===
# 缺少 key 时对应 provider 自动禁用，不会报错
TAVILY_API_KEY=
BRAVE_API_KEY=
GOOGLE_BOOKS_API_KEY=

# === LLM (Ollama) ===
ENABLE_LLM=true
OLLAMA_BASE_URL=http://192.168.1.50:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=120

# === Cloud LLM ===
# 统一云端 LLM 开关与 Provider 选择
ENABLE_CLOUD_LLM=false
CLOUD_LLM_PROVIDER=deepseek
CLOUD_LLM_TIMEOUT_SECONDS=120

# === Cloud LLM: DeepSeek ===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# === Cloud LLM: OpenAI ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4.1-mini

# === Cloud LLM: Generic OpenAI-compatible ===
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_DEFAULT_MODEL=

# === Search Defaults ===
DEFAULT_SEARCH_DEPTH=3
DEFAULT_RESULT_LIMIT=10

# === Provider Toggles ===
ENABLE_TAVILY=true
ENABLE_BRAVE=true
ENABLE_GOOGLE_BOOKS=true

# === Scoring Weights (0.0 - 1.0) ===
SCORING_AUTHORITY_WEIGHT=0.3
SCORING_RELEVANCE_WEIGHT=0.4
SCORING_ORIGINALITY_WEIGHT=0.2
SCORING_GOSSIP_PENALTY=0.1
